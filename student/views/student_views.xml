<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="course_view_form" model="ir.ui.view">
        <field name="name">student.view.form</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <form string="Student View">
                <header></header>
                <sheet>
                    <h1><field name="name"/></h1>
                    <group>
                        <group>
                            <separator string="Course Settings"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <separator string="Other Fields"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="student_view_list" model="ir.ui.view">
        <field name="name">student.view.list</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <tree string="Student List">
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>
    <record id="student_view_search" model="ir.ui.view">
        <field name="name">student.view.search</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="description"/>
            </search>
        </field>
    </record>
</odoo>